                this.scene.add(new THREE.AmbientLight(0xffffff, 0.7));\
                this.scene.add(new THREE.PointLight(0xffffff, 0.8, 100));\
                this.box = new THREE.LineSegments(new THREE.EdgesGeometry(new THREE.BoxGeometry(10, 10, 10)), new THREE.LineBasicMaterial(\{linewidth: 2\}));\

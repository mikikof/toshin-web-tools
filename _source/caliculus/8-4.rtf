                    const p = new THREE.Mesh(new THREE.SphereGeometry(0.15, 16, 16), new THREE.MeshPhongMaterial(\{ color: 0xffffff \}));\
                    p.position.set((Math.random()-0.5)*9, (Math.random()-0.5)*9, (Math.random()-0.5)*9);\
                    p.velocity = new THREE.Vector3(Math.random()-0.5, Math.random()-0.5, Math.random()-0.5).normalize();\

                \
                this.slicePlane = new THREE.Mesh(new THREE.PlaneGeometry(10, 5).rotateX(Math.PI / 2), new THREE.MeshBasicMaterial(\{ side: THREE.DoubleSide, transparent: true, opacity: 0.2 \}));\

            toggleWireframe() \{\
                this.surfaceMesh.material.wireframe = !this.surfaceMesh.material.wireframe;\
            \}\
\
            updateTheme() \{\
                const isLight = document.body.classList.contains('light-mode');\
                this.surfaceMesh.material.color.set(isLight ? 0x3b82f6 : 0x38bdf8);\

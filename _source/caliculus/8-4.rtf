        \
        class MacroViz \{\
            constructor(container) \{\
                this.container = container;\
                this.init();\
            \}\
\
            init() \{\
                this.scene = new THREE.Scene();\
                this.camera = new THREE.PerspectiveCamera(75, this.container.clientWidth / this.container.clientHeight, 0.1, 1000);\
                this.camera.up.set(0, 0, 1); // Z is up\
                this.camera.position.set(8, 8, 6);\
                \
                this.renderer = new THREE.WebGLRenderer(\{ antialias: true, alpha: true \});\
                this.renderer.setSize(this.container.clientWidth, this.container.clientHeight);\
                this.renderer.setClearColor(0x000000, 0);\
                this.container.appendChild(this.renderer.domElement);\
                \
                this.controls = new OrbitControls(this.camera, this.renderer.domElement);\
                this.controls.enableDamping = true;\
\
                const light1 = new THREE.DirectionalLight(0xffffff, 0.8);\
                light1.position.set(1, 1, 1);\
                this.scene.add(light1);\
                this.scene.add(new THREE.AmbientLight(0xdddddd));\
\
                const axisLength = 6;\
                const axisLineWidth = 3;\
                const createAxis = (vec, color) => new THREE.Line(\
                    new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0,0,0), vec.multiplyScalar(axisLength)]), \
                    new THREE.LineBasicMaterial(\{ color: color, linewidth: axisLineWidth \})\
                );\
                this.scene.add(createAxis(new THREE.Vector3(1,0,0), 0x0000ff)); // T-axis (x) -> Blue\
                this.scene.add(createAxis(new THREE.Vector3(0,1,0), 0xff0000)); // V-axis (y) -> Red\
                this.scene.add(createAxis(new THREE.Vector3(0,0,1), 0x00ff00)); // U-axis (z) -> Green\
\
                this.surfaceMesh = new THREE.Mesh(new THREE.PlaneGeometry(10, 10, 50, 50), new THREE.MeshPhongMaterial(\{ side: THREE.DoubleSide, transparent: true, opacity: 0.7, wireframe: false \}));\
                this.scene.add(this.surfaceMesh);\
\
                this.sliceLine = new THREE.Line(new THREE.BufferGeometry().setFromPoints(new Array(51).fill(new THREE.Vector3())), new THREE.LineBasicMaterial(\{ linewidth: 5 \}));\
                this.scene.add(this.sliceLine);\
                \
                this.pointMarker = new THREE.Mesh(new THREE.SphereGeometry(0.15, 16, 16), new THREE.MeshBasicMaterial());\

            \
            mapTo3D(T, V, U) \{\
                const x = (T - T_range.min) / (T_range.max - T_range.min) * 10 - 5;\
                const y = (V - V_range.min) / (V_range.max - V_range.min) * 10 - 5;\
                const z = (U - U_range.min) / (U_range.max - U_range.min) * 5 - 2.5;\
                return new THREE.Vector3(x, y, z);\

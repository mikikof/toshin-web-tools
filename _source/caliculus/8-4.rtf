                this.surfaceMesh.geometry.computeVertexNormals();\
            \}\
\
            update(T, V, n) \{\
                this.slicePlane.position.y = (V - V_range.min) / (V_range.max - V_range.min) * 10 - 5;\
                const slicePoints = [];\
                for (let i = 0; i <= 50; i++) \{\
                    const t_val = T_range.min + (T_range.max - T_range.min) * (i / 50);\
                    slicePoints.push(this.mapTo3D(t_val, V, internalEnergy(t_val, V, n)));\
                \}\
                this.sliceLine.geometry.setFromPoints(slicePoints);\
                this.pointMarker.position.copy(this.mapTo3D(T, V, internalEnergy(T, V, n)));\
            \}\

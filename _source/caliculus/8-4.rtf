\
            updateTheme() \{\
                 this.box.material.color.set(document.body.classList.contains('light-mode') ? 0x3b82f6 : 0x00ffff);\
            \}\
            \
            animate() \{\
                const volScale = this.box.scale.x;\
                const boundary = 5 * volScale - 0.15;\
                this.particles.forEach(p => \{\
                    p.position.add(p.velocity);\
                    if (Math.abs(p.position.x) > boundary) \{ p.position.x = Math.sign(p.position.x) * boundary; p.velocity.x *= -1; \}\
                    if (Math.abs(p.position.y) > boundary) \{ p.position.y = Math.sign(p.position.y) * boundary; p.velocity.y *= -1; \}\
                    if (Math.abs(p.position.z) > boundary) \{ p.position.z = Math.sign(p.position.z) * boundary; p.velocity.z *= -1; \}\
                \});\
            \}\
\
            onResize() \{\
                this.camera.aspect = this.container.clientWidth / this.container.clientHeight;\
                this.camera.updateProjectionMatrix();\
                this.renderer.setSize(this.container.clientWidth, this.container.clientHeight);\
            \}\
            \
            render() \{ this.renderer.render(this.scene, this.camera); \}\
        \}\
\
        class ChartViz \{\
            constructor() \{\
                this.chart = new Chart(document.getElementById('sliceChart').getContext('2d'), \{\
                    type: 'line',\
                    data: \{ labels: [], datasets: [\
                        \{ label: '\uc0\u20869 \u37096 \u12456 \u12493 \u12523 \u12462 \u12540  U', data: [], borderWidth: 2, tension: 0.1, pointRadius: 0 \},\
                        \{ label: '\uc0\u25509 \u32218 ', data: [], borderWidth: 1.5, pointRadius: 0, borderDash: [5, 5] \}\
                    ]\},\
                    options: \{ responsive: true, maintainAspectRatio: false, animation: \{ duration: 0 \} \}\
                \});\
                this.updateTheme();\
            \}\
            \
            update(T, V, n) \{\
                const current_U = internalEnergy(T, V, n);\
                const derivative = partial_U_partial_T(T, V, n); // This is C_V\
                \
                derivativeValueEl.textContent = molarHeatCapacity(T).toFixed(2);\
                \
                const T_values = Array.from(\{length: 51\}, (_, i) => T_range.min + (T_range.max - T_range.min) * (i / 50));\
                const U_values = T_values.map(t => internalEnergy(t, V, n));\
                const tangent_values = T_values.map(t => current_U + derivative * (t - T));\
                \
                this.chart.data.labels = T_values.map(t => t.toFixed(0));\
                this.chart.data.datasets[0].data = U_values;\
                this.chart.data.datasets[1].data = tangent_values;\
                this.chart.update('none');\
                chartVolumeLabel.textContent = V.toFixed(2);\
            \}\
\
            updateTheme() \{\
                const isLight = document.body.classList.contains('light-mode');\
                const textColor = isLight ? '#4b5563' : '#9ca3af';\
                const gridColor = isLight ? '#e5e7eb' : '#374151';\
                this.chart.data.datasets[0].borderColor = isLight ? 'rgb(37, 99, 235)' : 'rgb(56, 189, 248)';\
                this.chart.data.datasets[1].borderColor = isLight ? 'rgb(5, 150, 105)' : 'rgb(74, 222, 128)';\
                this.chart.options.scales.x.title.color = textColor;\
                this.chart.options.scales.x.ticks.color = textColor;\
                this.chart.options.scales.x.grid.color = gridColor;\
                this.chart.options.scales.y.title.color = textColor;\
                this.chart.options.scales.y.ticks.color = textColor;\
                this.chart.options.scales.y.grid.color = gridColor;\
                this.chart.options.scales.x.title.text = '\uc0\u28201 \u24230  T (K)';\
                this.chart.options.scales.y.title.text = 'U (J)';\
                this.chart.update('none');\
            \}\
        \}\
        \
        function updateAllVisualizations() \{\
            const T = parseFloat(sliders.T.value), V = parseFloat(sliders.V.value), n = parseFloat(sliders.n.value);\
            values.T.textContent = T.toFixed(0);\
            values.V.textContent = V.toFixed(2);\
            values.n.textContent = n.toFixed(2);\
            \
            macro_viz.update(T, V, n);\
            micro_viz.update(T, V);\
            chart_viz.update(T, V, n);\
        \}\
\
        function main() \{\
            macro_viz = new MacroViz(macroContainer);\
            micro_viz = new MicroViz(microContainer);\
            chart_viz = new ChartViz();\
            \
            // --- Theme Toggle ---\
            const toggleButton = document.getElementById('theme-toggle');\
            const sunIcon = document.getElementById('theme-icon-sun');\
            const moonIcon = document.getElementById('theme-icon-moon');\
            const applyTheme = (isLight) => \{\
                document.body.classList.toggle('light-mode', isLight);\
                sunIcon.classList.toggle('hidden', !isLight);\
                moonIcon.classList.toggle('hidden', isLight);\
                macro_viz.updateTheme();\
                micro_viz.updateTheme();\
                chart_viz.updateTheme();\
            \};\
            toggleButton.addEventListener('click', () => \{\
                const isLight = !document.body.classList.contains('light-mode');\
                localStorage.setItem('theme', isLight ? 'light' : 'dark');\
                applyTheme(isLight);\
            \});\
            \
            // --- Mesh Toggle ---\
            const meshToggleButton = document.getElementById('mesh-toggle');\
            meshToggleButton.addEventListener('click', () => \{\
                macro_viz.toggleWireframe();\
                meshToggleButton.classList.toggle('active', macro_viz.surfaceMesh.material.wireframe);\
            \});\
\
            // --- Event Listeners ---\
            sliders.T.addEventListener('input', updateAllVisualizations);\
            sliders.V.addEventListener('input', updateAllVisualizations);\
            sliders.n.addEventListener('input', () => \{\
                const n_val = parseFloat(sliders.n.value);\
                macro_viz.updateSurface(n_val);\
                micro_viz.updateParticleCount(n_val);\
                updateAllVisualizations();\
            \});\
            window.addEventListener('resize', () => \{\
                macro_viz.onResize();\
                micro_viz.onResize();\
            \});\
            \
            // --- Initial State ---\
            const n_val = parseFloat(sliders.n.value);\
            macro_viz.updateSurface(n_val);\
            micro_viz.updateParticleCount(n_val);\
            updateAllVisualizations();\
            applyTheme(localStorage.getItem('theme') === 'light');\
\
            function animate() \{\
                requestAnimationFrame(animate);\
                micro_viz.animate();\
                macro_viz.render();\
                micro_viz.render();\
            \}\
            animate();\
        \}\
\
        main();\
    \});\
</script>\
</body>\
</html>\
\
}
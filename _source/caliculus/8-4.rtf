            updateSurface(n) \{\
                const positions = this.surfaceMesh.geometry.attributes.position;\
                let maxU = -Infinity;\
                for (let i = 0; i < positions.count; i++) \{\
                    const T = (positions.getX(i) + 5) / 10 * (T_range.max - T_range.min) + T_range.min;\
                    const V = (positions.getY(i) + 5) / 10 * (V_range.max - V_range.min) + V_range.min;\
                    const U = internalEnergy(T, V, n);\
                    if (U > maxU) maxU = U;\
                \}\
                U_range.max = maxU > 0 ? maxU * 1.1 : 50000;\
                for (let i = 0; i < positions.count; i++) \{\
                    const T = (positions.getX(i) + 5) / 10 * (T_range.max - T_range.min) + T_range.min;\
                    const V = (positions.getY(i) + 5) / 10 * (V_range.max - V_range.min) + V_range.min;\
                    const U = internalEnergy(T, V, n);\
                    positions.setZ(i, (U - U_range.min) / (U_range.max - U_range.min) * 5 - 2.5);\

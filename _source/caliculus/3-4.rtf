<body class="bg-gray-100">\
\
    <div class="container mx-auto p-4 sm:p-8 max-w-5xl">\
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">\
            <div class="p-6 sm:p-8">\
                <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">\uc0\u12399 \u12373 \u12415 \u12358 \u12385 \u12398 \u21407 \u29702 </h1>\
                <p class="mt-2 text-gray-600">\uc0\u12464 \u12521 \u12501 \u12420 \u12473 \u12521 \u12452 \u12480 \u12540 \u12434 \u25805 \u20316 \u12375 \u12390 \u12289 \u12399 \u12373 \u12415 \u12358 \u12385 \u12398 \u21407 \u29702 \u12434 \u35222 \u35226 \u30340 \u12395 \u29702 \u35299 \u12375 \u12424 \u12358 \u12290 </p>\
            </div>\
\
            <div class="bg-blue-50 border-t border-b border-blue-200 px-6 sm:px-8 py-5">\
                <h2 class="text-lg font-bold text-blue-800 mb-3">\uc0\u12399 \u12373 \u12415 \u12358 \u12385 \u12398 \u21407 \u29702 \u12392 \u12399 \u65311 </h2>\
                <div class="text-blue-900 space-y-3">\
                    <p>\uc0\u38306 \u25968  $f(x), g(x)$ \u12398 \u23450 \u32681 \u22495 \u12364 \u38283 \u21306 \u38291  $I$ \u12434 \u21547 \u12415 , $a \\in I$ \u12392 \u12377 \u12427 \u12290 </p>\
                    <p>$\\lim_\{x \\to a\} f(x) = \\alpha$, $\\lim_\{x \\to a\} g(x) = \\beta$ \uc0\u12392 \u12377 \u12427 \u12392 \u12365 ,</p>\
                    <ol class="list-decimal list-inside space-y-2 pl-4">\
                        <li>\uc0\u12377 \u12409 \u12390 \u12398  $x \\in I$ \u12391  $f(x) \\leq g(x)$ \u12394 \u12425 \u12400  $\\alpha \\leq \\beta$</li>\
                        <li>\uc0\u38306 \u25968  $h(x)$ \u12364 \u38283 \u21306 \u38291  $I$ \u12434 \u21547 \u12415 , \u12377 \u12409 \u12390 \u12398  $x \\in I$ \u12395 \u12388 \u12356 \u12390 \
                            <br>\
                            $f(x) \\leq h(x) \\leq g(x)$ \uc0\u12363 \u12388  $\\alpha = \\beta$ \u12394 \u12425 \u12400 ,\
                            <br>\
                            $\\lim_\{x \\to a\} h(x) = \\alpha$  (\uc0\u12399 \u12373 \u12415 \u12358 \u12385 \u12398 \u21407 \u29702 )\
                        </li>\
                    </ol>\
                </div>\

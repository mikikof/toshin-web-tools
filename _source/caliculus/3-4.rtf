\
            <div class="p-6 sm:p-8">\
                <!-- Canvas for the graph -->\
                <div class="relative">\
                    <canvas id="squeezeTheoremCanvas" class="w-full h-64 sm:h-96 bg-gray-50 rounded-lg border-2 border-gray-200 cursor-crosshair"></canvas>\
                    <div id="valueDisplay" class="absolute top-2 left-2 bg-white bg-opacity-80 p-2 rounded-md shadow text-sm pointer-events-none">\
                        <p class="font-semibold text-gray-800">x = 0.00</p>\
                        <p style="color: #ef4444;">g(x) = 0.00</p>\
                        <p style="color: #22c55e;">h(x) = 0.00</p>\
                        <p style="color: #3b82f6;">f(x) = 0.00</p>\
                    </div>\
                </div>\
\
\
                <!-- Controls -->\
                <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">\
                    <div>\
                        <label for="squeezeFactor" class="block text-sm font-medium text-gray-700">\uc0\u25375 \u12415 \u36796 \u12416 \u24375 \u12373  (C)</label>\
                        <input type="range" id="squeezeFactor" min="0.1" max="4" step="0.05" value="1.5" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">\
                        <div class="text-right text-sm text-gray-500 mt-1">C = <span id="squeezeFactorValue">1.5</span></div>\
                    </div>\
                    <div>\
                        <label for="oscillation" class="block text-sm font-medium text-gray-700">h(x)\uc0\u12398 \u25391 \u21205  (D)</label>\
                        <input type="range" id="oscillation" min="1" max="80" step="1" value="25" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">\
                        <div class="text-right text-sm text-gray-500 mt-1">D = <span id="oscillationValue">25</span></div>\
                    </div>\
                </div>\
                <div class="mt-4 text-center text-gray-500 text-sm">\
                    <p>\uc0\u12461 \u12515 \u12531 \u12496 \u12473 \u19978 \u12391 \u12510 \u12454 \u12473 \u12434 \u21205 \u12363 \u12377 \u12392 \u12289 \u21508 \u38306 \u25968 \u12398 \u20516 \u12364 \u34920 \u31034 \u12373 \u12428 \u12414 \u12377 \u12290 </p>\
                </div>\
            </div>\
        </div>\
    </div>\
    \
    <script>\
        const canvas = document.getElementById('squeezeTheoremCanvas');\
        const ctx = canvas.getContext('2d');\
        const squeezeFactorSlider = document.getElementById('squeezeFactor');\
        const oscillationSlider = document.getElementById('oscillation');\
        const squeezeFactorValue = document.getElementById('squeezeFactorValue');\
        const oscillationValue = document.getElementById('oscillationValue');\
        const valueDisplay = document.getElementById('valueDisplay');\
\
        // Function definitions\
        // g(x) is the upper bounding function\
        const g = (x, C) => C * x * x;\
        // f(x) is the lower bounding function\
        const f = (x, C) => -C * x * x;\
        // h(x) is the function being squeezed\
        const h = (x, C, D) => \{\
            if (x === 0) return 0;\
            // Use the definition of g(x) to ensure h(x) is bounded correctly\
            return g(x, C) * Math.sin(D / x);\
        \};\
\
        // State object to hold parameters\
        let state = \{\
            C: parseFloat(squeezeFactorSlider.value),\
            D: parseFloat(oscillationSlider.value),\
            mouseX: null,\
            xRange: 5, // The graph will show x from -5 to 5\
        \};\
\
        // Colors for the functions\
        const colors = \{\
            g: '#ef4444', // red-500\
            h: '#22c55e', // green-500\
            f: '#3b82f6', // blue-500\
            axis: '#9ca3af', // gray-400\
            cursor: '#f97316', // orange-500\
        \};\
\
        // Function to draw everything on the canvas\
        function draw() \{\
            // Set canvas size based on its display size for high DPI screens\
            const rect = canvas.getBoundingClientRect();\
            canvas.width = rect.width * window.devicePixelRatio;\
            canvas.height = rect.height * window.devicePixelRatio;\
            ctx.scale(window.devicePixelRatio, window.devicePixelRatio);\
\
            const width = canvas.clientWidth;\
            const height = canvas.clientHeight;\
            \
            // Clear the canvas\
            ctx.clearRect(0, 0, width, height);\
\
            // Establish coordinate system\
            const xCenter = width / 2;\
            const yCenter = height / 2;\
            \
            // FIX: Use a fixed y-range to make the change in the 'C' parameter visible.\
            // The previous dynamic y-range (based on C) scaled the y-axis,\
            // which cancelled out the visual effect of changing C.\
            // This fixed value is chosen to accommodate the graph even at the maximum C value.\
            const yRange = 110; \
            \
            const xScale = width / (2 * state.xRange);\
            const yScale = height / (2 * yRange);\
\
            // --- Draw Axes ---\
            ctx.strokeStyle = colors.axis;\
            ctx.lineWidth = 1;\
            ctx.beginPath();\
            // X-axis\
            ctx.moveTo(0, yCenter);\
            ctx.lineTo(width, yCenter);\
            // Y-axis\
            ctx.moveTo(xCenter, 0);\
            ctx.lineTo(xCenter, height);\
            ctx.stroke();\
            \
            // Draw axis labels\
            ctx.fillStyle = colors.axis;\
            ctx.font = '12px Inter';\
            ctx.fillText('x', width - 15, yCenter - 5);\
            ctx.fillText('y', xCenter + 5, 15);\
            ctx.fillText('0', xCenter + 5, yCenter + 15);\
\
\
            // --- Draw Functions ---\
            const drawFunction = (func, color) => \{\
                ctx.beginPath();\
                ctx.strokeStyle = color;\
                ctx.lineWidth = 2.5;\
                \
                for (let i = 0; i <= width; i++) \{\
                    const x_canvas = i;\
                    // Convert canvas x to mathematical x\
                    const x_math = (x_canvas - xCenter) / xScale;\
                    const y_math = func(x_math);\
                    \
                    // Convert mathematical y to canvas y\
                    const y_canvas = yCenter - y_math * yScale;\
\
                    if (i === 0) \{\
                        ctx.moveTo(x_canvas, y_canvas);\
                    \} else \{\
                        ctx.lineTo(x_canvas, y_canvas);\
                    \}\
                \}\
                ctx.stroke();\
            \};\
\
            drawFunction(x => g(x, state.C), colors.g);\
            drawFunction(x => f(x, state.C), colors.f);\
            drawFunction(x => h(x, state.C, state.D), colors.h);\
            \
            // --- Draw Mouse Cursor and Values ---\
            if (state.mouseX !== null) \{\
                const x_canvas = state.mouseX;\
                const x_math = (x_canvas - xCenter) / xScale;\
\
                const y_g = g(x_math, state.C);\
                const y_f = f(x_math, state.C);\
                const y_h = h(x_math, state.C, state.D);\
\
                const y_g_canvas = yCenter - y_g * yScale;\
                const y_f_canvas = yCenter - y_f * yScale;\
                const y_h_canvas = yCenter - y_h * yScale;\
\
                // Draw vertical line\
                ctx.beginPath();\
                ctx.strokeStyle = colors.cursor;\
                ctx.setLineDash([4, 4]);\
                ctx.moveTo(x_canvas, 0);\
                ctx.lineTo(x_canvas, height);\
                ctx.stroke();\
                ctx.setLineDash([]);\
\
                // Draw points on each curve\
                const drawPoint = (y, color) => \{\
                    ctx.beginPath();\
                    ctx.fillStyle = color;\
                    ctx.arc(x_canvas, y, 5, 0, 2 * Math.PI);\
                    ctx.fill();\
                    ctx.strokeStyle = 'white';\
                    ctx.lineWidth = 2;\
                    ctx.stroke();\
                \};\
                drawPoint(y_g_canvas, colors.g);\
                drawPoint(y_f_canvas, colors.f);\
                drawPoint(y_h_canvas, colors.h);\
\
                // Update value display\
                valueDisplay.style.display = 'block';\
                valueDisplay.innerHTML = `\
                    <p class="font-semibold text-gray-800">x = $\{x_math.toFixed(2)\}</p>\
                    <p style="color: $\{colors.g\};">g(x) = $\{y_g.toFixed(2)\}</p>\
                    <p style="color: $\{colors.h\};">h(x) = $\{y_h.toFixed(2)\}</p>\
                    <p style="color: $\{colors.f\};">f(x) = $\{y_f.toFixed(2)\}</p>\
                `;\
            \} else \{\
                 valueDisplay.style.display = 'none';\
            \}\
        \}\
\
        // --- Event Listeners ---\
        squeezeFactorSlider.addEventListener('input', (e) => \{\
            state.C = parseFloat(e.target.value);\
            squeezeFactorValue.textContent = state.C.toFixed(2);\
            requestAnimationFrame(draw);\
        \});\
\
        oscillationSlider.addEventListener('input', (e) => \{\
            state.D = parseFloat(e.target.value);\
            oscillationValue.textContent = state.D;\
            requestAnimationFrame(draw);\
        \});\
        \
        canvas.addEventListener('mousemove', (e) => \{\
            const rect = canvas.getBoundingClientRect();\
            state.mouseX = e.clientX - rect.left;\
            requestAnimationFrame(draw);\
        \});\
        \
        canvas.addEventListener('mouseleave', () => \{\
            state.mouseX = null;\
            requestAnimationFrame(draw);\
        \});\
        \
        // Redraw on window resize\
        window.addEventListener('resize', () => \{\
            requestAnimationFrame(draw);\
        \});\
\
        // Initial draw\
        requestAnimationFrame(draw);\
    </script>\
\

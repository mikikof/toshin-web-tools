        <div class="card">\
            <h2 class="text-3xl font-bold text-center mb-6">\uc0\u12523 \u12505 \u12540 \u12464 \u31309 \u20998 \u12364 \u30495 \u20385 \u12434 \u30330 \u25582 \u12377 \u12427 \u19990 \u30028 </h2>\
            <div class="space-y-8 text-base md:text-lg leading-relaxed max-w-4xl mx-auto">\
                <div>\
                    <h3 class="text-xl font-bold mb-2 text-indigo-600">1. \uc0\u12487 \u12451 \u12522 \u12463 \u12524 \u38306 \u25968 \u65306 \u12522 \u12540 \u12510 \u12531 \u31309 \u20998 \u12434 \u22730 \u12377 \u12300 \u24847 \u22320 \u24746 \u12301 \u12394 \u20363 </h3>\
                    <p>\uc0\u12523 \u12505 \u12540 \u12464 \u31309 \u20998 \u12398 \u12377 \u12372 \u12373 \u12434 \u31034 \u12377 \u20856 \u22411 \u20363 \u12364 \u12300 \u12487 \u12451 \u12522 \u12463 \u12524 \u38306 \u25968 \u12301 \u12391 \u12377 \u12290 \u12371 \u12428 \u12399 \u12300 x\u12364 \u26377 \u29702 \u25968 \u12394 \u12425 1\u12289 \u28961 \u29702 \u25968 \u12394 \u12425 0\u12301 \u12392 \u12356 \u12358 \u20516 \u12434 \u21462 \u12427 \u38306 \u25968 \u12391 \u12289 \u28961 \u25968 \u12398 \u19981 \u36899 \u32154 \u28857 \u12434 \u25345 \u12385 \u12414 \u12377 \u12290 </p>\
                    <ul class="list-disc list-inside mt-2 space-y-1 pl-4">\
                        <li><b>\uc0\u12522 \u12540 \u12510 \u12531 \u31309 \u20998 \u12398 \u21839 \u38988 \u28857 :</b> \u12393 \u12435 \u12394 \u12395 \u32048 \u12356 \u30701 \u20874 \u12434 \u20316 \u12387 \u12390 \u12418 \u12289 \u12381 \u12398 \u20013 \u12395 \u12399 \u24517 \u12378 \u26377 \u29702 \u25968 \u12392 \u28961 \u29702 \u25968 \u12398 \u20001 \u26041 \u12364 \u21547 \u12414 \u12428 \u12414 \u12377 \u12290 \u12381 \u12398 \u12383 \u12417 \u12289 \u30701 \u20874 \u12398 \u39640 \u12373 \u12434 \u12300 1\u12301 \u12392 \u21462 \u12427 \u12371 \u12392 \u12418 \u12300 0\u12301 \u12392 \u21462 \u12427 \u12371 \u12392 \u12418 \u12391 \u12365 \u12390 \u12375 \u12414 \u12356 \u12289 \u38754 \u31309 \u12398 \u21512 \u35336 \u20516 \u12399 \u27770 \u12375 \u12390 \u19968 \u12388 \u12398 \u20516 \u12395 \u21454 \u26463 \u12375 \u12414 \u12379 \u12435 \u12290 \u35336 \u31639 \u12364 \u30772 \u32187 \u12375 \u12390 \u12375 \u12414 \u12358 \u12398 \u12391 \u12377 \u12290 </li>\
                        <li><b>\uc0\u12523 \u12505 \u12540 \u12464 \u31309 \u20998 \u12398 \u39854 \u12420 \u12363 \u12394 \u35299 \u27770 \u31574 :</b> \u12523 \u12505 \u12540 \u12464 \u12399 x\u36600 \u12391 \u12399 \u12394 \u12367 y\u36600 \u12434 \u35211 \u12414 \u12377 \u12290 \u12300 \u20516 \u12364 1\u12395 \u12394 \u12427 \u28857 \u12398 \u38598 \u12414 \u12426 \u65288 \u26377 \u29702 \u25968 \u20840 \u20307 \u65289 \u12301 \u12392 \u12300 \u20516 \u12364 0\u12395 \u12394 \u12427 \u28857 \u12398 \u38598 \u12414 \u12426 \u65288 \u28961 \u29702 \u25968 \u20840 \u20307 \u65289 \u12301 \u12395 \u20998 \u12369 \u12289 \u12381 \u12428 \u12382 \u12428 \u12398 \u38598 \u21512 \u12398 \u12300 \u22823 \u12365 \u12373 \u65288 \u28204 \u24230 \u65289 \u12301 \u12434 \u32771 \u12360 \u12414 \u12377 \u12290 \u25968 \u30452 \u32218 \u19978 \u12391 \u12399 \u12289 \u26377 \u29702 \u25968 \u12399 \u12473 \u12459 \u12473 \u12459 \u12391 \u28204 \u24230 \u12399 0\u12289 \u28961 \u29702 \u25968 \u12399 \u12403 \u12387 \u12375 \u12426 \u12391 \u28204 \u24230 \u12399 1\u65288 \u21306 \u38291 [0,1]\u12398 \u22580 \u21512 \u65289 \u12392 \u12394 \u12426 \u12414 \u12377 \u12290 \u12424 \u12387 \u12390 \u38754 \u31309 \u12399  <code class="bg-gray-100 p-1 rounded">(\u20516  1 \'d7 \u28204 \u24230  0) + (\u20516  0 \'d7 \u28204 \u24230  1) = 0</code> \u12392 \u12289 \u12356 \u12392 \u12418 \u31777 \u21336 \u12395 \u30906 \u23450 \u12375 \u12414 \u12377 \u12290 </li>\
                    </ul>\
                </div>\
                <div>\
                    <h3 class="text-xl font-bold mb-2 text-indigo-600">2. \uc0\u30906 \u29575 \u35542 \u12392 \u26399 \u24453 \u20516 \u65306 \u12300 \u31070 \u12398 \u35222 \u28857 \u12301 \u12398 \u35336 \u31639 \u26041 \u27861 </h3>\
                    <p>\uc0\u12300 \u12469 \u12452 \u12467 \u12525 \u12398 \u26399 \u24453 \u20516 \u12301 \u12434 \u35336 \u31639 \u12377 \u12427 \u12392 \u12365 \u12289 \u31169 \u12383 \u12385 \u12399 \u33258 \u28982 \u12395 \u12523 \u12505 \u12540 \u12464 \u31309 \u20998 \u30340 \u12394 \u32771 \u12360 \u26041 \u12434 \u12375 \u12390 \u12356 \u12414 \u12377 \u12290 \u35336 \u31639 \u24335 \u12399  `(1\u12398 \u30446  \'d7 1/6) + (2\u12398 \u30446  \'d7 1/6) + ...` \u12392 \u12394 \u12426 \u12414 \u12377 \u12364 \u12289 \u12371 \u12428 \u12399 \u12300 \u20986 \u12427 \u30446 \u65288 <b>\u20516 </b>\u65289 \u12301 \u12372 \u12392 \u12395 \u12464 \u12523 \u12540 \u12503 \u20998 \u12369 \u12375 \u12289 \u12300 \u12381 \u12398 \u20516 \u12364 \u20986 \u12427 <b>\u30906 \u29575 \u65288 \u28204 \u24230 \u65289 </b>\u12301 \u12434 \u25499 \u12369 \u12390 \u36275 \u12375 \u21512 \u12431 \u12379 \u12427 \u12289 \u12414 \u12373 \u12375 \u12367 \u12523 \u12505 \u12540 \u12464 \u12398 \u30330 \u24819 \u12391 \u12377 \u12290 </p>\
                    <p class="mt-2">\uc0\u23453 \u12367 \u12376 \u12398 \u12424 \u12358 \u12395 \u12289 \u30906 \u29575 \u12364 \u36899 \u32154 \u30340 \u12394 \u37096 \u20998 \u65288 \u12495 \u12474 \u12524 \u65289 \u12392 \u38626 \u25955 \u30340 \u12394 \u37096 \u20998 \u65288 \u12450 \u12479 \u12522 \u65289 \u12391 \u28151 \u22312 \u12375 \u12390 \u12356 \u12427 \u22580 \u21512 \u12289 \u12522 \u12540 \u12510 \u12531 \u31309 \u20998 \u12391 \u12399 \u12358 \u12414 \u12367 \u25201 \u12360 \u12414 \u12379 \u12435 \u12290 \u12375 \u12363 \u12375 \u12289 \u12523 \u12505 \u12540 \u12464 \u31309 \u20998 \u12394 \u12425 \u12289 \u20986 \u12427 \u20516 \u65288 \u36062 \u37329 \u65289 \u12391 \u12464 \u12523 \u12540 \u12503 \u20998 \u12369 \u12375 \u12289 \u12381 \u12428 \u12382 \u12428 \u12398 \u30906 \u29575 \u65288 \u28204 \u24230 \u65289 \u12434 \u25499 \u12369 \u12390 \u36275 \u12375 \u21512 \u12431 \u12379 \u12427 \u12384 \u12369 \u12391 \u12289 \u26399 \u24453 \u20516 \u12434 \u23436 \u29863 \u12395 \u35336 \u31639 \u12391 \u12365 \u12414 \u12377 \u12290 </p>\
                </div>\
                 <div>\
                    <h3 class="text-xl font-bold mb-2 text-indigo-600">3. \uc0\u20234 \u34276 \u31309 \u20998 \u12408 \u12398 \u26550 \u12369 \u27211 \u65306 \u12300 \u28204 \u12427 \u12514 \u12494 \u12469 \u12471 \u12301 \u12398 \u22793 \u26356 </h3>\
                    <p>\uc0\u12371 \u12398 \u12300 \u20309 \u12391 \u28204 \u12427 \u12363 \u12434 \u22793 \u12360 \u12427 \u12301 \u12392 \u12356 \u12358 \u12523 \u12505 \u12540 \u12464 \u12398 \u30330 \u24819 \u12399 \u12289 \u12373 \u12425 \u12395 \u30330 \u23637 \u12375 \u12414 \u12377 \u12290 \u37329 \u34701 \u24037 \u23398 \u12394 \u12393 \u12391 \u20351 \u12431 \u12428 \u12427 <b>\u20234 \u34276 \u31309 \u20998 </b>\u12399 \u12289 \u19981 \u35215 \u21063 \u12395 \u22793 \u21205 \u12377 \u12427 \u26666 \u20385 \u12394 \u12393 \u12434 \u25201 \u12358 \u12383 \u12417 \u12289 \u26178 \u38291 \u12398 \u36914 \u12415 \u26041 \u12381 \u12398 \u12418 \u12398 \u12434 \u12300 \u12521 \u12531 \u12480 \u12512 \u12394 \u12514 \u12494 \u12469 \u12471 \u65288 \u30906 \u29575 \u36942 \u31243 \u65289 \u12301 \u12391 \u28204 \u12426 \u30452 \u12375 \u12414 \u12377 \u12290 \u12371 \u12428 \u12418 \u12414 \u12383 \u12289 \u12523 \u12505 \u12540 \u12464 \u31309 \u20998 \u12398 \u12300 \u28204 \u12426 \u26041 \u12434 \u22793 \u12360 \u12427 \u12301 \u12392 \u12356 \u12358 \u38761 \u26032 \u30340 \u12394 \u12450 \u12452 \u12487 \u12450 \u12364 \u26681 \u24213 \u12395 \u12354 \u12427 \u12398 \u12391 \u12377 \u12290 </p>\
                </div>\
            </div>\

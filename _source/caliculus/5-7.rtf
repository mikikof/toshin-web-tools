\
    <script>\
        document.addEventListener('DOMContentLoaded', () => \{\
            if (typeof renderMathInElement === 'function') \{\
                renderMathInElement(document.body);\
            \}\
\
            class IntegralVisualizer \{\
                constructor(config) \{\
                    this.canvas = document.getElementById(config.canvasId);\
                    this.ctx = this.canvas.getContext('2d');\
                    this.modeSelector = document.getElementById(config.modeSelectorId);\
                    this.functionSelector = document.getElementById(config.functionSelectorId);\
                    this.slider = document.getElementById(config.sliderId);\
                    this.partitionLabel = document.getElementById(config.partitionLabelId);\
                    this.areaLabel = document.getElementById(config.areaLabelId);\
                    \
                    this.functions = config.functions;\
                    this.currentFunc = this.functions.simple;\
                    this.graph = config.graph;\
                    this.currentMode = 'riemann';\
                    this.partitions = parseInt(this.slider.value);\
                    \
                    this.setupCanvas();\
                    this.addEventListeners();\
                \}\
\
                setupCanvas() \{\
                    this.dpr = window.devicePixelRatio || 1;\
                    const rect = this.canvas.parentElement.getBoundingClientRect();\
                    this.width = rect.width;\
                    this.height = rect.height;\
                    this.canvas.width = this.width * this.dpr;\
                    this.canvas.height = this.height * this.dpr;\
                    this.canvas.style.width = `$\{this.width\}px`;\
                    this.canvas.style.height = `$\{this.height\}px`;\
                    this.ctx.scale(this.dpr, this.dpr);\
                    this.drawScene();\
                \}\
\
                toCX(x) \{ return this.graph.padding + (x - this.graph.xMin) / (this.graph.xMax - this.graph.xMin) * (this.width - 2 * this.graph.padding); \}\
                toCY(y) \{ return this.height - this.graph.padding - (y - this.graph.yMin) / (this.graph.yMax - this.graph.yMin) * (this.height - 2 * this.graph.padding); \}\
\
                drawAxesAndFunction() \{\
                    this.ctx.clearRect(0, 0, this.width, this.height);\
                    this.ctx.strokeStyle = '#d1d5db';\
                    this.ctx.lineWidth = 1;\
                    this.ctx.beginPath();\
                    this.ctx.moveTo(this.graph.padding, this.toCY(0));\
                    this.ctx.lineTo(this.width - this.graph.padding, this.toCY(0));\
                    this.ctx.moveTo(this.toCX(this.graph.xMin), this.graph.padding);\
                    this.ctx.lineTo(this.toCX(this.graph.xMin), this.height - this.graph.padding);\
                    this.ctx.stroke();\
\
                    this.ctx.strokeStyle = '#1f2937';\
                    this.ctx.lineWidth = 3;\
                    this.ctx.beginPath();\
                    for (let x = this.graph.xMin; x <= this.graph.xMax; x += 0.1) \{\
                        this.ctx.lineTo(this.toCX(x), this.toCY(this.currentFunc(x)));\
                    \}\
                    this.ctx.stroke();\
                \}\
\
                drawRiemann() \{\
                    const dx = (this.graph.xMax - this.graph.xMin) / this.partitions;\
                    let totalArea = 0;\
\
                    for (let i = 0; i < this.partitions; i++) \{\
                        const xStart = this.graph.xMin + i * dx;\
                        const y = this.currentFunc(xStart);\
                        \
                        totalArea += y * dx;\
\
                        const hue = (i / this.partitions) * 360;\
                        this.ctx.fillStyle = `hsla($\{hue\}, 90%, 70%, 0.7)`;\
                        this.ctx.strokeStyle = `hsla($\{hue\}, 90%, 50%, 0.5)`;\
                        this.ctx.lineWidth = 1;\
                        \
                        const cx = this.toCX(xStart);\
                        const cWidth = this.toCX(xStart + dx) - cx;\
                        \
                        this.ctx.fillRect(cx, this.toCY(y), cWidth, this.toCY(0) - this.toCY(y));\
                        this.ctx.strokeRect(cx, this.toCY(y), cWidth, this.toCY(0) - this.toCY(y));\
                    \}\
                    this.areaLabel.textContent = totalArea.toFixed(2);\
                \}\
\
                drawLebesgue() \{\
                    const yMinIntegration = 0;\
                    const yMaxIntegration = this.graph.yMax;\
                    const dy = (yMaxIntegration - yMinIntegration) / this.partitions;\
                    let totalArea = 0;\
\
                    for (let i = 0; i < this.partitions; i++) \{\
                        const y = yMinIntegration + i * dy;\
                        \
                        let measure = 0;\
                        let inSet = false;\
                        let startX = 0;\
                        const sampleStep = 0.02;\
\
                        for (let x = this.graph.xMin; x <= this.graph.xMax; x += sampleStep) \{\
                            const fx = this.currentFunc(x);\
                            const currentlyInSet = (fx >= y);\
                            if (currentlyInSet && !inSet) startX = x;\
                            if (!currentlyInSet && inSet) measure += (x - startX);\
                            inSet = currentlyInSet;\
                        \}\
                        if (inSet) measure += (this.graph.xMax - startX);\
\
                        if (measure > 0) \{\
                            totalArea += dy * measure;\
                            const hue = (y / this.graph.yMax) * 240 + 120;\
                            this.ctx.fillStyle = `hsla($\{hue\}, 90%, 70%, 0.7)`;\
                            this.ctx.strokeStyle = `hsla($\{hue\}, 90%, 40%, 1)`;\
                            this.ctx.lineWidth = 0.5;\
\
                            inSet = false;\
                            startX = 0;\
                            for (let x = this.graph.xMin; x <= this.graph.xMax; x += sampleStep) \{\
                                 const fx = this.currentFunc(x);\
                                 const currentlyInSet = (fx >= y);\
                                 if (currentlyInSet && !inSet) startX = x;\
                                 if (!currentlyInSet && inSet) \{\
                                     this.ctx.fillRect(this.toCX(startX), this.toCY(y + dy), this.toCX(x) - this.toCX(startX), this.toCY(y) - this.toCY(y + dy));\
                                     this.ctx.strokeRect(this.toCX(startX), this.toCY(y + dy), this.toCX(x) - this.toCX(startX), this.toCY(y) - this.toCY(y + dy));\
                                 \}\
                                 inSet = currentlyInSet;\
                            \}\
                            if(inSet)\{\
                                 this.ctx.fillRect(this.toCX(startX), this.toCY(y + dy), this.toCX(this.graph.xMax) - this.toCX(startX), this.toCY(y) - this.toCY(y + dy));\
                                 this.ctx.strokeRect(this.toCX(startX), this.toCY(y + dy), this.toCX(this.graph.xMax) - this.toCX(startX), this.toCY(y) - this.toCY(y + dy));\
                            \}\
                        \}\
                    \}\
                    this.areaLabel.textContent = totalArea.toFixed(2);\
                \}\
\
                drawScene() \{\
                    this.drawAxesAndFunction();\
                    if (this.currentMode === 'riemann') \{\
                        this.drawRiemann();\
                    \} else \{\
                        this.drawLebesgue();\
                    \}\
                \}\
\
                addEventListeners() \{\
                    this.modeSelector.addEventListener('click', (e) => \{\
                        if (e.target.classList.contains('btn-mode')) \{\
                            this.currentMode = e.target.dataset.mode;\
                            this.modeSelector.querySelectorAll('.btn-mode').forEach(btn => btn.classList.remove('active'));\
                            e.target.classList.add('active');\
                            this.drawScene();\
                        \}\
                    \});\
\
                    this.functionSelector.addEventListener('click', (e) => \{\
                        if (e.target.classList.contains('btn-mode')) \{\
                            const funcName = e.target.dataset.func;\
                            this.currentFunc = this.functions[funcName];\
                            this.functionSelector.querySelectorAll('.btn-mode').forEach(btn => btn.classList.remove('active'));\
                            e.target.classList.add('active');\
                            this.drawScene();\
                        \}\
                    \});\
\
                    this.slider.addEventListener('input', (e) => \{\
                        this.partitions = parseInt(e.target.value);\
                        this.partitionLabel.textContent = this.partitions;\
                        this.drawScene();\
                    \});\
\
                    window.addEventListener('resize', () => this.setupCanvas());\
                \}\
            \}\
\
            new IntegralVisualizer(\{\
                canvasId: 'integration-canvas',\
                modeSelectorId: 'mode-selector',\
                functionSelectorId: 'function-selector',\
                sliderId: 'partition-slider',\
                partitionLabelId: 'partition-label',\
                areaLabelId: 'area-value',\
                functions: \{\
                    simple: x => 5 * Math.sin(x / 5) + 5,\
                    complex: x => 2 * Math.sin(x / 1.5) + 3 * Math.cos(x / 4) + 5\
                \},\
                graph: \{ xMin: 0, xMax: 40, yMin: -2, yMax: 12, padding: 40 \}\
            \});\
        \});\
    </script>\
\
</body>\
</html>\
}
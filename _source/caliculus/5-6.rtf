        document.addEventListener('DOMContentLoaded', () => \{\
            // KaTeX\uc0\u12521 \u12452 \u12502 \u12521 \u12522 \u12391 \u25968 \u24335 \u12434 \u12524 \u12531 \u12480 \u12522 \u12531 \u12464 \
            if (typeof renderMathInElement === 'function') \{\

            \}\
\
            // --- \uc0\u23450 \u25968 \u12392 \u35373 \u23450  ---\
            const canvasFx = document.getElementById('canvas-fx');\
            const canvasIntegral = document.getElementById('canvas-integral');\
            const ctxFx = canvasFx.getContext('2d');\
            const ctxIntegral = canvasIntegral.getContext('2d');\
            const slider = document.getElementById('x-slider');\
            \
            const xValueLabel = document.getElementById('x-value-label');\
            const fxValueLabel = document.getElementById('fx-value');\
            const slopeValueLabel = document.getElementById('slope-value');\
            const integralValueLabel = document.getElementById('integral-value');\
            const equalityCheck = document.getElementById('equality-check');\
\
            const graphSettings = \{\
                xMin: -5, xMax: 45,\
                yMinFx: -30, yMaxFx: 50,\
                yMinIntegral: -200, yMaxIntegral: 1200,\
                padding: 40\
            \};\
\
            // --- \uc0\u25968 \u23398 \u38306 \u25968  ---\
            const f = x => -0.1 * x * (x - 40);\
            const F = x => -0.1 * (Math.pow(x, 3) / 3 - 20 * Math.pow(x, 2));\
\
            // --- \uc0\u25551 \u30011 \u12504 \u12523 \u12497 \u12540  ---\
            const toCanvasX = (x, width) => graphSettings.padding + (x - graphSettings.xMin) / (graphSettings.xMax - graphSettings.xMin) * (width - 2 * graphSettings.padding);\
            const toCanvasY = (y, height, yMin, yMax) => height - graphSettings.padding - (y - yMin) / (yMax - yMin) * (height - 2 * graphSettings.padding);\
\
            // --- \uc0\u12513 \u12452 \u12531 \u25551 \u30011 \u38306 \u25968  ---\
            function drawScene() \{\
                if (!slider) return;\
\
                const w = canvasFx.getBoundingClientRect().width;\
                const h = canvasFx.getBoundingClientRect().height;\
                const xVal = slider.value / 10;\
\
                ctxFx.clearRect(0, 0, canvasFx.width, canvasFx.height);\
                ctxIntegral.clearRect(0, 0, canvasIntegral.width, canvasIntegral.height);\
\
                drawAxes(ctxFx, w, h, graphSettings.yMinFx, graphSettings.yMaxFx, 'f(x)');\
                drawAxes(ctxIntegral, w, h, graphSettings.yMinIntegral, graphSettings.yMaxIntegral, 'F(x) = \uc0\u8747 f(t)dt');\
\
                plotFunction(ctxFx, f, w, h, graphSettings.yMinFx, graphSettings.yMaxFx, '#3b82f6', 3);\
                plotFunction(ctxIntegral, F, w, h, graphSettings.yMinIntegral, graphSettings.yMaxIntegral, '#16a34a', 3);\
                \
                shadeArea(ctxFx, f, w, h, xVal);\
\
                const cx = toCanvasX(xVal, w);\
                const cy_fx = toCanvasY(f(xVal), h, graphSettings.yMinFx, graphSettings.yMaxFx);\
                drawDot(ctxFx, cx, cy_fx, '#3b82f6');\
\
                const cy_integral = toCanvasY(F(xVal), h, graphSettings.yMinIntegral, graphSettings.yMaxIntegral);\
                drawDot(ctxIntegral, cx, cy_integral, '#16a34a');\
                \
                drawTangent(ctxIntegral, xVal, w, h);\
\
                xValueLabel.textContent = xVal.toFixed(1);\
                fxValueLabel.textContent = f(xVal).toFixed(2);\
                slopeValueLabel.textContent = f(xVal).toFixed(2);\
                integralValueLabel.textContent = F(xVal).toFixed(2);\
                \
                if(equalityCheck) \{\
                    equalityCheck.style.transform = 'scale(1.1)';\
                    setTimeout(() => \{ equalityCheck.style.transform = 'scale(1.0)'; \}, 150);\
                \}\
            \}\
\
            // --- \uc0\u12469 \u12502 \u25551 \u30011 \u38306 \u25968  ---\
            function drawAxes(ctx, w, h, yMin, yMax, label) \{\
                ctx.beginPath();\
                ctx.strokeStyle = '#d1d5db';\
                ctx.lineWidth = 1;\
                const yZero = toCanvasY(0, h, yMin, yMax);\
                ctx.moveTo(0, yZero);\
                ctx.lineTo(w, yZero);\
                const xZero = toCanvasX(0, w);\
                ctx.moveTo(xZero, 0);\
                ctx.lineTo(xZero, h);\
                ctx.stroke();\
                \
                ctx.fillStyle = '#9ca3af';\
                ctx.font = '14px Inter';\
                ctx.textAlign = 'left';\
                ctx.fillText(label, graphSettings.padding, graphSettings.padding - 5);\
            \}\
\
            function plotFunction(ctx, func, w, h, yMin, yMax, color, lineWidth) \{\
                ctx.beginPath();\
                ctx.strokeStyle = color;\
                ctx.lineWidth = lineWidth;\
                const step = (graphSettings.xMax - graphSettings.xMin) / w;\
                for (let x = graphSettings.xMin; x <= graphSettings.xMax; x += step) \{\
                    const cx = toCanvasX(x, w);\
                    const cy = toCanvasY(func(x), h, yMin, yMax);\
                    if (x === graphSettings.xMin) \{\
                        ctx.moveTo(cx, cy);\
                    \} else \{\
                        ctx.lineTo(cx, cy);\
                    \}\
                \}\
                ctx.stroke();\
            \}\
            \
            function shadeArea(ctx, func, w, h, xEnd) \{\
                const yZero = toCanvasY(0, h, graphSettings.yMinFx, graphSettings.yMaxFx);\
                ctx.fillStyle = 'rgba(59, 130, 246, 0.2)';\
                ctx.beginPath();\
                ctx.moveTo(toCanvasX(0, w), yZero);\
                const step = (xEnd) / 100;\
                for (let x = 0; x <= xEnd; x += step) \{\
                    ctx.lineTo(toCanvasX(x, w), toCanvasY(func(x), h, graphSettings.yMinFx, graphSettings.yMaxFx));\
                \}\
                ctx.lineTo(toCanvasX(xEnd, w), yZero);\
                ctx.closePath();\
                ctx.fill();\
            \}\
\
            function drawDot(ctx, cx, cy, color) \{\
                ctx.beginPath();\
                ctx.fillStyle = color;\
                ctx.arc(cx, cy, 6, 0, Math.PI * 2);\
                ctx.fill();\
            \}\
            \
            function drawTangent(ctx, x, w, h) \{\
                const slope = f(x);\
                const pointX = x;\
                const pointY = F(x);\
                \
                const tangentLength = 10;\
                const x1 = pointX - tangentLength / 2;\
                const y1 = pointY - slope * (tangentLength / 2);\
                const x2 = pointX + tangentLength / 2;\
                const y2 = pointY + slope * (tangentLength / 2);\
\
                ctx.beginPath();\
                ctx.strokeStyle = '#ef4444';\
                ctx.lineWidth = 2.5;\
                ctx.moveTo(toCanvasX(x1, w), toCanvasY(y1, h, graphSettings.yMinIntegral, graphSettings.yMaxIntegral));\
                ctx.lineTo(toCanvasX(x2, w), toCanvasY(y2, h, graphSettings.yMinIntegral, graphSettings.yMaxIntegral));\
                ctx.stroke();\
            \}\
\
            // --- \uc0\u21021 \u26399 \u21270 \u12392 \u12452 \u12505 \u12531 \u12488 \u12522 \u12473 \u12490 \u12540  ---\
            function setup() \{\
                const dpr = window.devicePixelRatio || 1;\
                \
                const setCanvasSize = (canvas) => \{\
                    if (!canvas || !canvas.parentElement) return;\
                    const rect = canvas.parentElement.getBoundingClientRect();\
                    canvas.width = rect.width * dpr;\
                    canvas.height = rect.height * dpr;\
                    canvas.style.width = `$\{rect.width\}px`;\
                    canvas.style.height = `$\{rect.height\}px`;\
                    const ctx = canvas.getContext('2d');\
                    ctx.scale(dpr, dpr);\
                \};\
\
                setCanvasSize(canvasFx);\
                setCanvasSize(canvasIntegral);\
                \
                drawScene();\
            \}\
\
            if (slider) \{\
                slider.addEventListener('input', drawScene);\
            \}\
            window.addEventListener('resize', setup);\
            \
            setup();\
        \});\
    </script>\
